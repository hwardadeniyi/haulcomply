generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  truckCount Int      @default(0)
  createdAt  DateTime @default(now())
  users      User[]
  drivers    Driver[]
  vehicles   Vehicle[]
  documents  Document[]
  deadlines  Deadline[]
  subs       Subscription[]
}

model User {
  id        String   @id @default(cuid())
  accountId String
  email     String   @unique
  name      String?
  password  String
  role      String   @default("owner")
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id])
}

model Driver {
  id        String   @id @default(cuid())
  accountId String
  name      String
  phone     String?
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id])
  documents Document[]
}

model Vehicle {
  id        String   @id @default(cuid())
  accountId String
  unitNo    String
  vin       String?
  plate     String?
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id])
  documents Document[]
}

model Document {
  id        String   @id @default(cuid())
  accountId String
  driverId  String?
  vehicleId String?
  docType   String
  fileKey   String
  fileName  String
  mimeType  String
  issuedAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id])
  driver    Driver?  @relation(fields: [driverId], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([accountId])
  @@index([driverId])
  @@index([vehicleId])
}

model Deadline {
  id          String   @id @default(cuid())
  accountId   String
  title       String
  category    String
  dueDate     DateTime
  status      String   @default("open")
  createdAt   DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id])
  reminders   ReminderEvent[]
}

model ReminderEvent {
  id         String   @id @default(cuid())
  deadlineId String
  channel    String
  scheduled  DateTime
  sentAt     DateTime?
  status     String   @default("queued")

  deadline   Deadline @relation(fields: [deadlineId], references: [id])
}

model Subscription {
  id              String   @id @default(cuid())
  accountId       String
  stripeCustomerId String?
  stripeSubId     String?
  plan            String?
  status          String   @default("inactive")
  createdAt       DateTime @default(now())

  account         Account  @relation(fields: [accountId], references: [id])
}
